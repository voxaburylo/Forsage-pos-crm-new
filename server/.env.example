# ─── Server ──────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ─── Supabase ─────────────────────────────────────────────────────────────────
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_KEY=your_service_role_key_here

# ─── Auth ─────────────────────────────────────────────────────────────────────
JWT_SECRET=your_super_secret_jwt_key_here_min_32_chars

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Через кому для кількох origins
CORS_ORIGIN=http://localhost:5173

# ─── Telegram Bot ─────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
# ID чату для Telegram-сповіщень менеджерам
MANAGER_CHAT_ID=123456789

# ─── Google Gemini OCR (для розпізнавання фото в чаті) ───────────────────────
# Необов'язково — якщо не вказано, OCR вимкнений
GEMINI_API_KEY=

# ─── Feature flags (POS) ──────────────────────────────────────────────────────
# process_sale_v2 — перевіряє qty_available з урахуванням резервів
USE_RESERVE_AWARE_SALE=true
# process_sale_v3 — бонуси списуються атомарно в межах одного RPC
USE_BONUS_ATOMIC_SALE=true
# complete_customer_order RPC — атомарне завершення замовлення
USE_ATOMIC_COMPLETION=true

# ─── Seed (лише для першого запуску seed.ts) ──────────────────────────────────
SEED_OWNER_PHONE=+380000000000
SEED_OWNER_PASSWORD=your_owner_password
